# -----------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real keys.
# -----------------------------------------------------------

# OpenAI API Key - required for GPT chat models AND for embeddings
# (embeddings are always OpenAI, even if LLM_PROVIDER=anthropic)
OPENAI_API_KEY=sk-...

# Anthropic API Key - required for Claude chat models
ANTHROPIC_API_KEY=sk-ant-...

# Default chat provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Supabase project #1 - SQL Assistant data source
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase project #2 - pgvector store for the Docs Assistant (RAG)
# Use the "Connection string" (URI) from Project Settings -> Database.
# Port 6543 = Transaction pooler (PgBouncer) - supported via prepare_threshold=None
# Port 5432 = Session pooler / direct connection - also works
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-x-region.pooler.supabase.com:6543/postgres

# RAG configuration
EMBEDDING_MODEL=text-embedding-3-small
RAG_COLLECTION_NAME=langchain_docs
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
